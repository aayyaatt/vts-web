<log4net threshold="ON">
  <!--
	Remove threshold="off" or set to on for activation
  -->
  <appender name="RollingFile" type="log4net.Appender.RollingFileAppender">
	<file value="omsc.log" />
	<appendToFile value="true" />
	<maximumFileSize value="500KB" />
	<maxSizeRollBackups value="10" />

	<layout type="log4net.Layout.PatternLayout">
    <conversionPattern value="%date %-5level [%thread] [%.8logger] - %message%newline" />
	</layout>
	  <!--
				<layout type="log4net.Layout.PatternLayout">
					<conversionPattern value="%date %level [%thread] (%file:%line) %logger - %message%newline" />
          <conversionPattern value="%date %-5level [%thread] [%.8logger] - %message%newline" />               
				</layout>
	  -->
  </appender>
  
  <root>
    <!-- <level value="DEBUG" /> -->
    <level value="ERROR" />
    <appender-ref ref="RollingFile" />
  </root>
  
</log4net>